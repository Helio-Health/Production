'use client'

import { useState } from 'react'
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
)

export default function Home() {
  const [email, setEmail] = useState('')
  const [type, setType] = useState<'patient' | 'doctor'>('patient')
  const [city, setCity] = useState('')
  const [status, setStatus] = useState<'idle' | 'loading' | 'success' | 'error'>('idle')

  async function handleSubmit() {
    if (!email) return
    setStatus('loading')

    const { error } = await supabase
      .from('waitlist')
      .insert([{ email, type, city }])

    if (error) {
      if (error.code === '23505') {
        // duplicate email
        setStatus('success')
      } else {
        setStatus('error')
      }
    } else {
      setStatus('success')
    }
  }

  return (
    <main className="min-h-screen bg-white flex flex-col">

      {/* Nav */}
      <nav className="px-8 py-6 flex items-center justify-between max-w-5xl mx-auto w-full">
        <span className="text-2xl font-semibold tracking-tight text-slate-900">helio</span>
        <span className="text-sm text-slate-400">heliohealth.app</span>
      </nav>

      {/* Hero */}
      <section className="flex-1 flex flex-col items-center justify-center px-6 text-center py-24">
        <div className="max-w-2xl mx-auto">

          <span className="inline-block bg-blue-50 text-blue-600 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
            Coming soon to your city
          </span>

          <h1 className="text-5xl font-bold tracking-tight text-slate-900 leading-tight mb-6">
            Find a doctor who actually <span className="text-blue-500">gets you</span>
          </h1>

          <p className="text-xl text-slate-500 mb-12 leading-relaxed">
            Not just whoever has an opening Tuesday at 2pm. Helio matches you with a primary care doctor based on how they communicate, what they value, and how they practice — not just their availability.
          </p>

          {status === 'success' ? (
            <div className="bg-green-50 border border-green-100 rounded-2xl p-8">
              <div className="text-3xl mb-3">🎉</div>
              <h3 className="text-lg font-semibold text-slate-900 mb-1">You're on the list</h3>
              <p className="text-slate-500 text-sm">We'll reach out when Helio launches in your area.</p>
            </div>
          ) : (
            <div className="bg-slate-50 border border-slate-100 rounded-2xl p-6 max-w-md mx-auto">

              {/* Patient / Doctor toggle */}
              <div className="flex bg-white border border-slate-200 rounded-xl p-1 mb-4">
                <button
                  onClick={() => setType('patient')}
                  className={`flex-1 py-2 text-sm font-medium rounded-lg transition-all ${
                    type === 'patient'
                      ? 'bg-blue-500 text-white shadow-sm'
                      : 'text-slate-500 hover:text-slate-700'
                  }`}
                >
                  I'm a patient
                </button>
                <button
                  onClick={() => setType('doctor')}
                  className={`flex-1 py-2 text-sm font-medium rounded-lg transition-all ${
                    type === 'doctor'
                      ? 'bg-blue-500 text-white shadow-sm'
                      : 'text-slate-500 hover:text-slate-700'
                  }`}
                >
                  I'm a doctor
                </button>
              </div>

              <input
                type="email"
                placeholder="your@email.com"
                value={email}
                onChange={e => setEmail(e.target.value)}
                className="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 mb-3 text-sm"
              />

              <input
                type="text"
                placeholder="Your city (optional)"
                value={city}
                onChange={e => setCity(e.target.value)}
                className="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 mb-4 text-sm"
              />

              <button
                onClick={handleSubmit}
                disabled={status === 'loading' || !email}
                className="w-full bg-blue-500 hover:bg-blue-600 disabled:bg-slate-300 text-white font-medium py-3 rounded-xl transition-colors text-sm"
              >
                {status === 'loading' ? 'Joining...' : type === 'doctor' ? 'Join as a doctor' : 'Join the waitlist'}
              </button>

              {status === 'error' && (
                <p className="text-red-500 text-xs mt-3 text-center">Something went wrong. Please try again.</p>
              )}

              <p className="text-xs text-slate-400 mt-3 text-center">No spam. Just a heads up when we launch.</p>
            </div>
          )}
        </div>
      </section>

      {/* Three value props */}
      <section className="border-t border-slate-100 py-16 px-6">
        <div className="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
          <div>
            <div className="text-3xl mb-3">🤝</div>
            <h3 className="font-semibold text-slate-900 mb-2">Matched on fit</h3>
            <p className="text-slate-500 text-sm leading-relaxed">Communication style, care philosophy, cultural background. Not just who takes your insurance.</p>
          </div>
          <div>
            <div className="text-3xl mb-3">🎥</div>
            <h3 className="font-semibold text-slate-900 mb-2">Meet them first</h3>
            <p className="text-slate-500 text-sm leading-relaxed">Watch a short intro video from your doctor before you ever book. Know who you're walking in to see.</p>
          </div>
          <div>
            <div className="text-3xl mb-3">💬</div>
            <h3 className="font-semibold text-slate-900 mb-2">Real reviews</h3>
            <p className="text-slate-500 text-sm leading-relaxed">Reviews about whether they listened, not just wait times. Find someone patients actually trust.</p>
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer className="border-t border-slate-100 py-6 px-6 text-center text-xs text-slate-400">
        © {new Date().getFullYear()} Helio Health · heliohealth.app
      </footer>

    </main>
  )
}